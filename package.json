{
  "name": "myphone",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "services:start": "./scripts/services.sh start",
    "services:stop": "./scripts/services.sh stop",
    "services:restart": "./scripts/services.sh restart",
    "services:status": "./scripts/services.sh status",
    "services:logs": "./scripts/services.sh logs",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "pnpm -r lint",
    "prisma:generate": "pnpm --filter api prisma:generate",
    "prisma:migrate": "pnpm --filter api prisma:migrate",
    "prisma:seed": "pnpm --filter api prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "~5.8.3"
  }
}
